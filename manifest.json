{
  "manifest_version": 2,
  "name": "YouTube Translator",
  "version": "0.1",
  "description": "Detects YouTube videos and shows a translated transcript sidebar",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "http://localhost:5000/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Translator"
  },
  "web_accessible_resources": ["content/injected.js"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/injector.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/transcript.js", "content/translate.js", "content/sidebar.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ]
}