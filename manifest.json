{
  "manifest_version": 2,
  "name": "YouTube Translator",
  "version": "0.1",
  "description": "Detects YouTube videos and shows a translated transcript sidebar",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "http://localhost:5000/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Translator"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/content.js"]
    }
  ]
}